{
  "name": "gearbox-code",
  "version": "0.1.34",
  "description": "A beautiful multi-provider coding harness for the terminal. (Intelligent model routing lands on top of this soon.)",
  "type": "module",
  "license": "MIT",
  "bin": {
    "gearbox": "dist/cli.mjs"
  },
  "files": [
    "dist/cli.mjs",
    "install.sh",
    "install.ps1"
  ],
  "scripts": {
    "start": "bun run src/cli.tsx",
    "gearbox": "bun run src/cli.tsx",
    "link": "bun link",
    "build": "node scripts/gen-docs.mjs && bun build --target=node src/cli.tsx --outfile dist/cli.mjs && node scripts/add-shebang.mjs",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "devDependencies": {
    "@ai-sdk/amazon-bedrock": "3",
    "@ai-sdk/anthropic": "^2.0.0",
    "@ai-sdk/azure": "2",
    "@ai-sdk/deepseek": "^1.0.0",
    "@ai-sdk/google": "^2.0.0",
    "@ai-sdk/google-vertex": "3",
    "@ai-sdk/openai": "^2.0.0",
    "@types/bun": "^1.3.14",
    "@types/diff": "^8.0.0",
    "@types/node": "^25.9.1",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^18.3.0",
    "ai": "^5.0.0",
    "diff": "^9.0.0",
    "ink": "^5.0.0",
    "ink-testing-library": "^4.0.0",
    "js-tiktoken": "^1.0.21",
    "marked": "15",
    "pngjs": "^7.0.0",
    "react": "^18.3.1",
    "typescript": "^5.6.0",
    "zod": "^3.25.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
