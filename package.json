{
  "name": "gearbox",
  "version": "0.1.0",
  "description": "A beautiful multi-provider coding harness for the terminal. (Intelligent model routing lands on top of this soon.)",
  "type": "module",
  "license": "MIT",
  "bin": {
    "gearbox": "src/cli.tsx"
  },
  "scripts": {
    "start": "bun run src/cli.tsx",
    "gearbox": "bun run src/cli.tsx",
    "link": "bun link",
    "build": "bun build --compile src/cli.tsx --outfile dist/gearbox",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.0",
    "@ai-sdk/deepseek": "^1.0.0",
    "@ai-sdk/google": "^2.0.0",
    "@ai-sdk/openai": "^2.0.0",
    "@inkjs/ui": "^2.0.0",
    "ai": "^5.0.0",
    "diff": "^9.0.0",
    "ink": "^5.0.0",
    "marked": "15",
    "react": "^18.3.1",
    "react-devtools-core": "^7.0.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/diff": "^8.0.0",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.0",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.6.0"
  }
